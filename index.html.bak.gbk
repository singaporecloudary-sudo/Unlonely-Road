<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, maximum-scale=1.0">
  <title>鍚堟垚椋炶溅灏勫嚮</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body {
      width: 100%; height: 100%;
      overflow: hidden;
      background: #000;
      display: flex;
      justify-content: center;
      align-items: center;
      touch-action: none;
      -webkit-touch-callout: none;
      -webkit-user-select: none;
      user-select: none;
    }
    canvas {
      display: block;
      image-rendering: pixelated;
    }
    /* 鍔犺浇鐢婚潰 */
    #loading {
      position: absolute;
      width: 100%; height: 100%;
      background: #1a1a2e;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      color: #FFF;
      font-family: Arial, sans-serif;
      z-index: 100;
    }
    #loading h1 { font-size: 36px; margin-bottom: 20px; color: #7C4DFF; }
    #loading p { font-size: 16px; color: #9E9E9E; }
    .loading-bar {
      width: 300px; height: 6px;
      background: #333; border-radius: 3px;
      margin-top: 20px; overflow: hidden;
    }
    .loading-bar-fill {
      width: 0%; height: 100%;
      background: #7C4DFF; border-radius: 3px;
      transition: width 0.3s;
    }
    /* 缂栬緫鍣ㄥ紑鍏?*/
    #editor-toggle {
      position: fixed;
      bottom: 10px; right: 10px;
      width: 40px; height: 40px;
      background: rgba(124,77,255,0.8);
      border: none; border-radius: 50%;
      color: #FFF; font-size: 20px;
      cursor: pointer; z-index: 200;
      display: flex; justify-content: center; align-items: center;
    }
    #editor-toggle:hover { background: rgba(124,77,255,1); }
  </style>
</head>
<body>
  <!-- 鍔犺浇鐢婚潰 -->
  <div id="loading">
    <h1>鍚堟垚椋炶溅灏勫嚮</h1>
    <p>姝ｅ湪鍔犺浇娓告垙璧勬簮...</p>
    <div class="loading-bar"><div class="loading-bar-fill" id="load-bar"></div></div>
  </div>

  <!-- 娓告垙鐢诲竷 -->
  <canvas id="gameCanvas"></canvas>

  <!-- 缂栬緫鍣ㄥ紑鍏?-->
  <button id="editor-toggle" title="闆朵唬鐮佺紪杈戝櫒">鈿?/button>

  <!-- ERROR DEBUG: capture script errors -->
  <script>window.__scriptErrors = []; window.addEventListener('error', function(e) { window.__scriptErrors.push({msg:e.message, file:e.filename, line:e.lineno, col:e.colno}); });</script>

  <!-- 閰嶇疆鏂囦欢 -->
  <script src="config/game-config.js?v=8"></script>
  <script src="config/asset-config.js?v=34"></script>

  <!-- 鏍稿績寮曟搸 -->
  <script src="src/core/engine.js?v=5"></script>
  <script src="src/core/state.js?v=5"></script>

  <!-- 娓告垙妯″潡 -->
  <script src="src/modules/crafting/crafting-scene.js?v=104"></script>
  <script src="src/modules/battle/battle-scene.js?v=43"></script>

  <!-- 缂栬緫鍣?-->
  <script src="src/editor/component-editor.js?v=11"></script>

  <!-- 涓诲叆鍙?-->
  <script>
    // 鍏ㄥ眬寮曠敤
    window.gameState = gameState;

    // ========== 鍔犺浇娴佺▼ ==========
    const loadBar = document.getElementById('load-bar');
    const loadingEl = document.getElementById('loading');
    let loadProgress = 0;

    function updateLoad(progress) {
      loadProgress = progress;
      loadBar.style.width = progress + '%';
    }

    // ========== 鍒濆鍖栨父鎴?==========
    async function initGame() {
      updateLoad(10);

      // 棰勫姞杞界編鏈礌鏉?      await new Promise(function(resolve) {
        var done = false;
        AssetConfig.preloadAll(function(progress) {
          updateLoad(10 + Math.floor(progress * 30));
          if (progress >= 1 && !done) {
            done = true;
            resolve();
          }
        });
        // 3绉掕秴鏃讹紙鍗充娇鍥剧墖鏈叏閮ㄥ姞杞戒篃缁х画锛?        setTimeout(function() {
          if (!done) { done = true; resolve(); }
        }, 3000);
      });

      updateLoad(40);

      // 鍔犺浇鑷畾涔夐厤缃?      const editor = new ComponentEditor();
      editor.loadCustomConfig();
      window.componentEditor = editor;

      updateLoad(50);

      // 鍒涘缓寮曟搸
      const engine = new GameEngine('gameCanvas');
      window.gameEngine = engine;

      updateLoad(60);

      // 娉ㄥ唽鍦烘櫙
      engine.registerScene('crafting', new CraftingScene());
      engine.registerScene('battle', new BattleScene());

      // ========== 缂栬緫鍣ㄦ覆鏌撻挬瀛愶紙鍦╯tart涔嬪墠璁剧疆锛?==========
      const _originalLoopFn = engine._loop.bind(engine);
      engine._loop = function() {
        if (!engine.running) return;
        const now = performance.now();
        engine.deltaTime = (now - engine.lastTime) / 1000;
        engine.lastTime = now;
        if (engine.deltaTime > 0.1) engine.deltaTime = 0.016;

        const scene = engine.scenes[engine.currentScene];
        if (scene) {
          scene.update(engine.deltaTime);
          scene.render(engine.ctx);
          if (window.componentEditor && window.componentEditor.visible) {
            window.componentEditor.render(engine.ctx);
          }
        }

        requestAnimationFrame(() => engine._loop());
      };

      updateLoad(80);

      // 鍔犺浇瀛樻。锛堜复鏃讹細娓呴櫎鏃у瓨妗ｄ互淇杞﹁締涓㈠け闂锛屽悗缁彲鍒犻櫎姝よ锛?      try {
        localStorage.removeItem('merge_racer_shooter_save');
        const savedData = null; // 寮哄埗浣跨敤鏂伴粯璁ゆ暟鎹?        if (savedData) {
          gameState.deserialize(savedData);
          console.log('瀛樻。宸插姞杞?);
        } else {
          console.log('浣跨敤榛樿鏁版嵁锛堝惈3杈嗗垵濮嬭溅杈嗭級');
        }
      } catch(e) {
        console.warn('瀛樻。鍔犺浇澶辫触锛屼娇鐢ㄩ粯璁ゆ暟鎹?', e);
      }

      updateLoad(100);

      // 鍒囨崲鍒颁富鐣岄潰
      engine.switchScene('crafting');

      // 闅愯棌鍔犺浇鐢婚潰
      setTimeout(() => {
        loadingEl.style.display = 'none';
        engine.start();
      }, 500);

      // ========== 缂栬緫鍣ㄦ寜閿?==========
      document.getElementById('editor-toggle').addEventListener('click', () => {
        editor.toggle();
      });

      // 缂栬緫鍣ㄨЕ鎽告嫤鎴?- 缁熶竴鐨勫潗鏍囪浆鎹㈠嚱鏁?      const canvas = document.getElementById('gameCanvas');
      const getCanvasPos = (e) => {
        const rect = canvas.getBoundingClientRect();
        const touch = e.touches ? e.touches[0] : (e.changedTouches ? e.changedTouches[0] : e);
        const scaleX = 720 / canvas.clientWidth;
        const scaleY = 1280 / canvas.clientHeight;
        return {
          x: (touch.clientX - rect.left) * scaleX,
          y: (touch.clientY - rect.top) * scaleY,
        };
      };

      // touchstart / mousedown
      canvas.addEventListener('touchstart', (e) => {
        if (editor.visible) {
          var pos = getCanvasPos(e);
          editor.handleTouchDown(pos); // 婊氬姩鍑嗗
          editor.handleClick(pos);
          e.preventDefault();
        }
      }, { passive: false });

      canvas.addEventListener('mousedown', (e) => {
        if (editor.visible) {
          var pos = getCanvasPos(e);
          editor.handleTouchDown(pos); // 婊氬姩鍑嗗
          editor.handleClick(pos);
        }
      });

      // touchmove / mousemove - 鎷栨嫿鏀寔
      canvas.addEventListener('touchmove', (e) => {
        if (editor.visible) {
          editor.handleMove(getCanvasPos(e));
          e.preventDefault();
        }
      }, { passive: false });

      canvas.addEventListener('mousemove', (e) => {
        if (editor.visible && e.buttons > 0) {
          editor.handleMove(getCanvasPos(e));
        }
      });

      // touchend / mouseup - 鎷栨嫿缁撴潫
      canvas.addEventListener('touchend', (e) => {
        if (editor.visible) {
          var pos;
          if (e.changedTouches && e.changedTouches[0]) {
            const rect = canvas.getBoundingClientRect();
            const scaleX = 720 / canvas.clientWidth;
            const scaleY = 1280 / canvas.clientHeight;
            pos = {
              x: (e.changedTouches[0].clientX - rect.left) * scaleX,
              y: (e.changedTouches[0].clientY - rect.top) * scaleY,
            };
          } else {
            pos = { x: 0, y: 0 };
          }
          editor.handleUp(pos);
        }
      }, { passive: false });

      canvas.addEventListener('mouseup', (e) => {
        if (editor.visible) {
          editor.handleUp(getCanvasPos(e));
        }
      });

      // 婊氳疆浜嬩欢锛堢紪杈戝櫒鍒楄〃婊氬姩锛?      canvas.addEventListener('wheel', (e) => {
        if (editor.visible) {
          e.preventDefault();
          editor.handleWheel(e.deltaY > 0 ? 1 : -1);
        }
      }, { passive: false });

      // ========== 鑷姩淇濆瓨 ==========
      setInterval(() => {
        engine.saveManager.save(gameState.serialize());
      }, 30000); // 姣?0绉掕嚜鍔ㄥ瓨妗?
      // ========== 椤甸潰鍏抽棴鏃朵繚瀛?==========
      window.addEventListener('beforeunload', () => {
        engine.saveManager.save(gameState.serialize());
      });
    }

    // 鍚姩
    initGame().then(() => {
      console.log('娓告垙鍒濆鍖栧畬鎴?);
    }).catch(err => {
      console.error('娓告垙鍒濆鍖栧け璐?', err);
      loadingEl.innerHTML = '<h1 style="color:#F44336">鍔犺浇澶辫触</h1><p>' + (err && err.message ? err.message : '鏈煡閿欒') + '</p>';
      // 3绉掑悗寮哄埗闅愯棌loading锛岃鐢ㄦ埛鑳界湅鍒癱anvas
      setTimeout(() => {
        if (loadingEl) loadingEl.style.display = 'none';
      }, 3000);
    });
  </script>
</body>
</html>
